#!/usr/bin/env python3
"""Copy the last fenced code block from recent Claude transcripts to clipboard."""
import json, re, subprocess, sys
from pathlib import Path
import os

projects_dir = Path.home() / '.claude' / 'projects'
transcripts = sorted(projects_dir.rglob('*.jsonl'), key=os.path.getmtime, reverse=True)

for transcript in transcripts[:20]:
    last_text = ''
    try:
        with open(transcript) as f:
            for line in f:
                try:
                    entry = json.loads(line)
                    msg = entry.get('message', {})
                    if msg.get('role') == 'assistant':
                        for block in msg.get('content', []):
                            if block.get('type') == 'text':
                                last_text = block['text']
                except Exception:
                    pass
    except Exception:
        continue

    blocks = re.findall(r'```(?:\w+)?\n(.*?)```', last_text, re.DOTALL)
    if blocks:
        code = blocks[-1].strip()
        subprocess.run(['xclip', '-selection', 'clipboard'], input=code.encode())
        print(f'copied {len(code)} chars to clipboard', file=sys.stderr)
        sys.exit(0)

sys.exit(1)
