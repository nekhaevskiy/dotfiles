# Theme
theme = one-dark

# Font
config-file = config-font

# Window
window-theme = ghostty
window-padding-x = 4
window-padding-y = 4
confirm-close-surface=false
resize-overlay = never
gtk-toolbar-style = flat

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Disable default fullscreen toggle
keybind = ctrl+enter=unbind

# Clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Scrolling
keybind = ctrl+shift+page_up=scroll_page_lines:-1
keybind = ctrl+shift+page_down=scroll_page_lines:1
keybind = shift+up=scroll_page_lines:-1
keybind = shift+down=scroll_page_lines:1
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom
keybind = ctrl+shift+u=scroll_page_up
keybind = ctrl+shift+d=scroll_page_down
keybind = ctrl+shift+y=scroll_page_lines:-1
keybind = ctrl+shift+e=scroll_page_lines:1

# Splits
keybind = ctrl+shift+backslash=new_split:right
keybind = ctrl+shift+minus=new_split:down
keybind = ctrl+shift+h=previous_tab
keybind = ctrl+shift+j=scroll_page_lines:1
keybind = ctrl+shift+k=scroll_page_lines:-1
keybind = ctrl+shift+l=next_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+equal=equalize_splits
keybind = ctrl+shift+alt+h=resize_split:left,10
keybind = ctrl+shift+alt+l=resize_split:right,10
keybind = ctrl+shift+alt+k=resize_split:up,10
keybind = ctrl+shift+alt+j=resize_split:down,10
keybind = ctrl+shift+r=reload_config
keybind = shift+enter=text:\x1b\r

# Tabs
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+1=goto_tab:1
keybind = ctrl+shift+2=goto_tab:2
keybind = ctrl+shift+3=goto_tab:3
keybind = ctrl+shift+4=goto_tab:4
keybind = ctrl+shift+5=goto_tab:5
keybind = ctrl+shift+6=goto_tab:6
keybind = ctrl+shift+7=goto_tab:7
keybind = ctrl+shift+8=goto_tab:8
keybind = ctrl+shift+9=goto_tab:9
keybind = ctrl+shift+left_bracket=previous_tab
keybind = ctrl+shift+right_bracket=next_tab

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
